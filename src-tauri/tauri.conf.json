{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "MikeDown",
  "version": "0.8.0",
  "identifier": "com.aidreamworks.mikedown",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "role": "Viewer",
        "mimeType": "text/markdown"
      }
    ]
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "MikeDown",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay"
      }
    ]
  }
}
